# ============================================================
#  CASAI — Variáveis de Ambiente (EXEMPLO)
#  Copie para .env e preencha. NUNCA commite o .env real.
# ============================================================

# --- Banco de dados ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/casai_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/casai_test

# --- Auth ---
JWT_SECRET=mude_para_um_segredo_forte_de_no_minimo_32_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# --- Login com Google (opcional — sem isso o botão Google não aparece) ---
# Crie um OAuth Client ID (tipo "Web application") em
# https://console.cloud.google.com/apis/credentials e adicione as origens
# autorizadas (http://localhost:3000 e a URL pública do deploy).
# O MESMO valor vai nas duas variáveis (a NEXT_PUBLIC_ é a usada pelo navegador).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Criptografia de credenciais de dispositivo (32 bytes hex) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CASAI_ENCRYPTION_KEY=

# --- Voz (Whisper no hub) ---
WHISPER_MODEL=small          # tiny | base | small  (small precisa ~4GB RAM)
WHISPER_LANGUAGE=pt

# --- Energia ---
ENERGY_POLL_INTERVAL_SECONDS=5

# --- Demo pública (deploy do TCC) ---
# true = semeia usuário demo + dispositivos MOCK + rotinas no boot (idempotente).
DEMO_MODE=false

# --- IoT: credenciais dos dispositivos (apenas para os spikes de validação) ---
# Em produção, ficam criptografadas no banco. Aqui só para testar o hardware.
TUYA_EWS410_ID=
TUYA_EWS410_KEY=
TUYA_EWS410_IP=
TUYA_PROTOCOL_VERSION=3.3

TAPO_P110_IP=
TAPO_EMAIL=
TAPO_PASS=

# --- MQTT (Zigbee, fase futura) ---
MQTT_HOST=localhost
MQTT_PORT=1883
